{
  "name": "doppl-kernel-rebuild",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "pnpm typecheck && pnpm proof",
    "assay": "node --experimental-strip-types tools/assay.ts",
    "serve": "node --experimental-strip-types tools/serve.ts",
    "assay:local": "node --experimental-strip-types tools/serve.ts",
    "assay:report": "node --experimental-strip-types tools/assay-report.ts",
    "architecture": "node --experimental-strip-types tools/microscope/architecture.ts",
    "publish:html": "pnpm microscope && pnpm architecture && pnpm assay && node --experimental-strip-types tools/publish.ts",
    "microscope": "node --experimental-strip-types tools/microscope/view.ts",
    "walkthrough": "node --experimental-strip-types tools/microscope/walkthrough.ts",
    "walkthrough:detail": "node --experimental-strip-types tools/microscope/walkthrough.ts --detail",
    "proof": "node --experimental-strip-types tools/run.ts",
    "proof:export": "node --experimental-strip-types tools/run.ts --export-proof-board",
    "kernel": "node --experimental-strip-types tools/run.ts",
    "kernel:compare": "node --experimental-strip-types tools/run.ts --fixture=fixtures/fsd-seed.json",
    "kernel:diverge": "node --experimental-strip-types tools/run.ts --dial=diverge --fixture=fixtures/fsd-seed.json",
    "kernel:converge": "node --experimental-strip-types tools/run.ts --dial=converge --fixture=fixtures/fsd-seed.json",
    "kernel:both": "pnpm kernel:diverge && pnpm kernel:converge"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
