# Default backend: OpenRouter (cheap hosted models)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# --- Optional: local open-source models (run with `./demo --local`) ---
# Point at any OpenAI-compatible endpoint (Ollama, LM Studio, etc.) serving e.g.
# qwen3.6:35b-a3b / gemma4 / Hermes. No API key needed for most local servers.
# NOTE: --local currently forces ONE model for every role (spawner+debaters+judge),
# which collapses cross-lab diversity. See MEMORY.md "Spawner selects the substrate".
# LOCAL_BASE_URL=http://localhost:11434/v1   # Ollama default
# LOCAL_MODEL=qwen3.6:35b-a3b

# --- Optional: override the hosted backend without --local ---
# CRUCIBLE_BASE_URL=https://openrouter.ai/api/v1
# CRUCIBLE_MODEL=                              # force one model for every role
