#!/usr/bin/env bash
# Mark a candidate promoted/rejected (append-only lifecycle). See mark.py.
set -euo pipefail
cd "$(dirname "$0")"
if [[ -f .venv/bin/activate ]]; then
  source .venv/bin/activate
elif [[ -f ../../.venv/bin/activate ]]; then
  source ../../.venv/bin/activate
fi
PY="$(command -v python || command -v python3)"
exec "$PY" mark.py "$@"
